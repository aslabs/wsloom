{
  "name": "@wsloom/core",
  "version": "0.1.0",
  "description": "Core protocol, router, and types for Loom RPC",
  "license": "Apache-2.0",
  "author": "wsloom contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wsloom/loom.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/wsloom/loom/tree/master/packages/core#readme",
  "bugs": "https://github.com/wsloom/loom/issues",
  "keywords": [
    "rpc",
    "websocket",
    "typescript",
    "realtime",
    "websocket-rpc",
    "wsloom",
    "protocol",
    "router",
    "middleware"
  ],
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "vitest": "^3.2.4"
  }
}
